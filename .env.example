# Copiar como .env y usar la misma contraseña del SQL Server de requirements-platform.
MSSQL_SA_PASSWORD=UseTheExistingRequirementsSqlPassword
MSSQL_DATABASE=AgendamientoMKT
MSSQL_HOST=requirements-sqlserver
MSSQL_EXTERNAL_PORT=14333
REQUIREMENTS_NETWORK=requirements-platform_default
# Clave maestra Base64 de 32 bytes. No reutilizar entre ambientes.
AGENDAMIENTO_MASTER_KEY=REPLACE_WITH_BASE64_ENCODED_32_BYTE_KEY
ADMIN_EMAIL=admin@agendamientomkt.local
API_PORT=5200
WEB_PORT=3001
APP_PORT=8088
